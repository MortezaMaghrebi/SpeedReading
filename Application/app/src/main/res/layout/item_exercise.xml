<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_exercise_card"
    android:orientation="horizontal"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="52dp"
        android:layout_height="52dp"
        android:background="@drawable/bg_exercise_icon"
        android:gravity="center">

        <ImageView
            android:id="@+id/ivExerciseIcon"
            android:layout_width="24dp"
            android:layout_height="24dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:layout_marginStart="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvExerciseTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#1A2639"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvExerciseDesc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#7B8AA0"
            android:textSize="14sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvExerciseBadge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="#4A6CF7"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:radius="30dp"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:textStyle="bold" />
</LinearLayout>