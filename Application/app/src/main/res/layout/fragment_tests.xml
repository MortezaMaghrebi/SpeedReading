<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scrollTests"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="16dp">

        <!-- باکس تست -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_test_box"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- نمایش زبان فعلی -->
            <TextView
                android:id="@+id/tvLanguageInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                android:text="🌐 فارسی"
                android:textColor="#6B7A8F"
                android:textSize="14sp"
                android:textStyle="bold" />

            <!-- TextView برای نمایش متن تست -->
            <TextView
                android:id="@+id/tvTestText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_test_text"
                android:fontFamily="sans-serif"
                android:gravity="start"
                android:padding="16dp"
                android:textColor="#1A2639"
                android:textSize="16sp"
                android:lineHeight="28sp"
                android:textIsSelectable="true"
                android:scrollbars="none" />

            <!-- دکمه شروع تست / پایان مطالعه / تست مجدد -->
            <Button
                android:id="@+id/btnTestStart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_primary"
                android:padding="12dp"
                android:text="شروع تست"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- دکمه عدم ذخیره نتیجه (مخفی در حالت عادی) -->
            <Button
                android:id="@+id/btnDiscardResult"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_button_danger"
                android:padding="12dp"
                android:text="عدم ذخیره نتیجه"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold"
                android:visibility="gone" />

        </LinearLayout>

        <!-- نمودار پیشرفت -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_chart_container"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chart" />

                <TextView
                    android:id="@+id/tvChartTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="پیشرفت تست‌ها (کلمه بر دقیقه)"
                    android:textColor="#6B7A8F"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- نمودار با MPAndroidChart -->
            <com.github.mikephil.charting.charts.LineChart
                android:id="@+id/chartProgress"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tvNoData"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="20dp"
                android:text="هنوز تستی ثبت نشده"
                android:textColor="#B0BED0"
                android:textSize="14sp" />

        </LinearLayout>

        <!-- جدول تاریخچه تست‌ها -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_chart_container"
            android:orientation="vertical"
            android:padding="20dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_history"
                    android:tint="#6B7A8F" />

                <TextView
                    android:id="@+id/tvHistoryTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="تاریخچه تست‌ها"
                    android:textColor="#6B7A8F"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:nestedScrollingEnabled="false" />

            <TextView
                android:id="@+id/tvNoHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:padding="20dp"
                android:text="هیچ تستی ثبت نشده"
                android:textColor="#B0BED0"
                android:textSize="14sp"
                android:visibility="gone" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>